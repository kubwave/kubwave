{
	"name": "cli",
	"version": "0.0.0-dev",
	"description": "kubwave installer and operations CLI.",
	"private": true,
	"author": "KinTex",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/kubwave/kubwave.git",
		"directory": "apps/cli"
	},
	"bugs": {
		"url": "https://github.com/kubwave/kubwave/issues"
	},
	"homepage": "https://github.com/kubwave/kubwave/tree/main/apps/cli",
	"type": "module",
	"bin": {
		"kubwave": "./src/index.ts"
	},
	"scripts": {
		"_prepare-embedded": "mkdir -p build/embedded && touch build/embedded/helm build/embedded/chart.tgz",
		"predev": "bun run _prepare-embedded",
		"prebuild": "bun run _prepare-embedded",
		"prebuild:linux-x64": "bun run _prepare-embedded",
		"prebuild:linux-arm64": "bun run _prepare-embedded",
		"prebuild:darwin-x64": "bun run _prepare-embedded",
		"prebuild:darwin-arm64": "bun run _prepare-embedded",
		"prebuild:docker": "bun run _prepare-embedded",
		"precheck-types": "bun run _prepare-embedded",
		"dev": "bun run src/index.ts",
		"build": "bun build --compile --define \"KUBWAVE_CLI_VERSION=\\\"${KUBWAVE_VERSION:-dev}\\\"\" --define \"KUBWAVE_HELM_VERSION=\\\"${KUBWAVE_HELM_VERSION:-not embedded}\\\"\" src/index.ts --outfile dist/kubwave",
		"build:docker": "bun build --compile --target=bun-linux-x64-baseline --define \"KUBWAVE_CLI_VERSION=\\\"${KUBWAVE_VERSION:-dev}\\\"\" --define \"KUBWAVE_HELM_VERSION=\\\"${KUBWAVE_HELM_VERSION:-not embedded}\\\"\" src/index.ts --outfile dist/kubwave",
		"build:linux-x64": "bun build --compile --target=bun-linux-x64-baseline --define \"KUBWAVE_CLI_VERSION=\\\"${KUBWAVE_VERSION:-dev}\\\"\" --define \"KUBWAVE_HELM_VERSION=\\\"${KUBWAVE_HELM_VERSION:-not embedded}\\\"\" src/index.ts --outfile dist/kubwave-linux-x64",
		"build:linux-arm64": "bun build --compile --target=bun-linux-arm64-baseline --define \"KUBWAVE_CLI_VERSION=\\\"${KUBWAVE_VERSION:-dev}\\\"\" --define \"KUBWAVE_HELM_VERSION=\\\"${KUBWAVE_HELM_VERSION:-not embedded}\\\"\" src/index.ts --outfile dist/kubwave-linux-arm64",
		"build:darwin-x64": "bun build --compile --target=bun-darwin-x64-baseline --define \"KUBWAVE_CLI_VERSION=\\\"${KUBWAVE_VERSION:-dev}\\\"\" --define \"KUBWAVE_HELM_VERSION=\\\"${KUBWAVE_HELM_VERSION:-not embedded}\\\"\" src/index.ts --outfile dist/kubwave-darwin-x64",
		"build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64-baseline --define \"KUBWAVE_CLI_VERSION=\\\"${KUBWAVE_VERSION:-dev}\\\"\" --define \"KUBWAVE_HELM_VERSION=\\\"${KUBWAVE_HELM_VERSION:-not embedded}\\\"\" src/index.ts --outfile dist/kubwave-darwin-arm64",
		"build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64",
		"check-types": "tsc --noEmit",
		"test": "bun test --isolate test",
		"test:coverage": "bun test --isolate --coverage --coverage-reporter=text --coverage-reporter=lcov test"
	},
	"dependencies": {
		"@kubwave/crypto": "workspace:*",
		"@kubwave/kube": "workspace:*",
		"@clack/prompts": "^1.6.0",
		"@kubernetes/client-node": "^1.2.0",
		"commander": "^15.0.0",
		"postgres": "^3.4.9",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"typescript": "^6.0.3"
	}
}
