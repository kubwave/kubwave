{
	"name": "backend",
	"version": "0.0.0",
	"description": "kubwave NestJS backend API and worker runtimes.",
	"private": true,
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/kubwave/kubwave.git",
		"directory": "apps/backend"
	},
	"bugs": {
		"url": "https://github.com/kubwave/kubwave/issues"
	},
	"homepage": "https://github.com/kubwave/kubwave/tree/main/apps/backend",
	"type": "module",
	"scripts": {
		"dev": "node --watch --import @swc-node/register/esm-register src/main-api.ts",
		"dev:worker": "node --watch --import @swc-node/register/esm-register src/main-worker.ts",
		"start": "node --import @swc-node/register/esm-register src/main-api.ts",
		"start:worker": "node --import @swc-node/register/esm-register src/main-worker.ts",
		"build": "tsc -p tsconfig.build.json",
		"check-types": "tsc --noEmit",
		"openapi:generate": "node --import @swc-node/register/esm-register src/generate-openapi.ts ../../packages/api-client/openapi.json",
		"test": "bun test --isolate test",
		"test:coverage": "bun test --isolate --coverage --coverage-reporter=text --coverage-reporter=lcov test"
	},
	"dependencies": {
		"@fastify/cookie": "^11.0.2",
		"@fastify/websocket": "^11.2.0",
		"@kubernetes/client-node": "^1.2.0",
		"@kubwave/crypto": "workspace:*",
		"@kubwave/db": "workspace:*",
		"@kubwave/kube": "workspace:*",
		"@kubwave/templates": "workspace:*",
		"@nestjs/common": "^11.1.27",
		"@nestjs/core": "^11.1.27",
		"@nestjs/platform-fastify": "^11.1.27",
		"@nestjs/swagger": "^11.4.4",
		"@nestjs/throttler": "^6.4.0",
		"argon2": "^0.44.0",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"jose": "^6.2.3",
		"nodemailer": "^9.0.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@nestjs/testing": "^11.0.0",
		"@swc-node/register": "^1.11.1",
		"@swc/core": "^1.15.43",
		"@types/bun": "^1.3.14",
		"@types/node": "^24.0.0",
		"@types/nodemailer": "^8.0.1",
		"typescript": "^6.0.3"
	}
}
