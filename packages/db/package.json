{
	"name": "@kubwave/db",
	"version": "0.0.0",
	"description": "kubwave database schema, client, and migrations.",
	"private": true,
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/kubwave/kubwave.git",
		"directory": "packages/db"
	},
	"bugs": {
		"url": "https://github.com/kubwave/kubwave/issues"
	},
